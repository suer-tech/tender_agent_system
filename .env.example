TG_TOKEN=your_new_bot_token_here
TG_ALLOWED_CHAT_ID=your_chat_id_here

# Bicotender.ru (optional — enables filters & document download)
BICOTENDER_LOGIN=your_login
BICOTENDER_PASSWORD=your_password

# EIS DIS — документо-информационный сервис zakupki.gov.ru (замена FTP с 01.01.2025)
# Получить: https://zakupki.gov.ru/pmd/auth/welcome → через Госуслуги → регистрация
#          потребителя машиночитаемых данных (физлицо) → токен выдаётся сразу.
# Используется sources/eis_dis.py для исторической аналитики контрактов и извещений.
EIS_DIS_TOKEN=

# LLM: выбор провайдера для оценки тендеров и генерации текстов в чате.
# Default: openrouter (работает из РФ без VPN).
LLM_PROVIDER=openrouter

# OpenRouter — https://openrouter.ai/keys. Первая модель — основная, вторая —
# фоллбэк при недоступности/ошибке первой.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_FALLBACK_MODEL=x-ai/grok-4.1-fast
# Опциональные поля (OpenRouter использует их для атрибуции):
# OPENROUTER_REFERER=https://your-domain.com
# OPENROUTER_APP_NAME=tender-agent

# Альтернатива: LLM_PROVIDER=claude использует локальный `claude -p` CLI.
# Требует залогиненного Claude Code на машине и не-РФ IP.
